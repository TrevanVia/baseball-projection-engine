{
  "manifest_version": 3,
  "name": "Capsolver Cloudflare Bypass",
  "version": "1.0",
  "permissions": ["declarativeNetRequest", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
